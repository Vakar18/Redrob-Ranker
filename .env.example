# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_NAME=redrob-ranker

# ─────────────────────────────────────────────
# MongoDB
# ─────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/redrob_ranker
MONGODB_DB_NAME=redrob_ranker

# ─────────────────────────────────────────────
# Redis (BullMQ)
# ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─────────────────────────────────────────────
# FREE LLM Providers (pick any / all)
# Priority order: GROQ → GEMINI → OLLAMA → deterministic-only
# ─────────────────────────────────────────────

# Option 1: Groq — FREE, very fast, generous limits
# Sign up at https://console.groq.com (no credit card needed)
GROQ_API_KEY=

# Option 2: Google Gemini — FREE tier (60 req/min, 1500 req/day)
# Get key at https://aistudio.google.com/app/apikey (free, no billing)
GEMINI_API_KEY=

# Option 3: Ollama — 100% local, zero cost, no internet needed
# Install: https://ollama.com  then run: ollama pull llama3.1
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Which provider to use first (groq | gemini | ollama | none)
LLM_PROVIDER=groq
# Fallback if primary fails (groq | gemini | ollama | none)
LLM_FALLBACK_PROVIDER=gemini

# ─────────────────────────────────────────────
# Ranking Config
# ─────────────────────────────────────────────
RANKING_BATCH_SIZE=50
RANKING_CONCURRENCY=5
RANKING_TOP_N=100
RANKING_JOB_TIMEOUT_MS=600000

# Scoring Weights
WEIGHT_SKILL_MATCH=0.35
WEIGHT_CAREER_FIT=0.30
WEIGHT_BEHAVIORAL=0.20
WEIGHT_AVAILABILITY=0.15
