{
  "name": "redrob-ranker",
  "version": "1.0.0",
  "description": "Redrob Intelligent Candidate Discovery & Ranking System",
  "author": "Redrob Hackathon Team",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "ingest": "node scripts/ingest-candidates.js",
    "rank": "node scripts/generate-submission.js",
    "rank:groq": "node scripts/generate-submission.js --provider groq",
    "rank:gemini": "node scripts/generate-submission.js --provider gemini",
    "rank:ollama": "node scripts/generate-submission.js --provider ollama",
    "rank:free": "node scripts/generate-submission.js --provider groq --fallback gemini",
    "rank:offline": "node scripts/generate-submission.js --no-llm",
    "validate": "python3 scripts/validate_submission.py"
  },
  "dependencies": {
    "@bull-board/express": "^8.0.1",
    "@bull-board/nestjs": "^8.0.1",
    "@bull-board/ui": "^8.0.1",
    "@google/generative-ai": "^0.21.0",
    "@nestjs/bull": "^10.2.3",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.0.0",
    "@nestjs/mongoose": "^10.0.10",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/throttler": "^6.2.1",
    "bullmq": "^5.28.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.7.4",
    "dotenv": "^17.4.2",
    "express-basic-auth": "^1.2.1",
    "groq-sdk": "^0.9.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "mongoose": "^8.9.4",
    "nest-winston": "^1.10.2",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "uuid": "^11.0.5",
    "winston": "^3.17.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/compression": "^1.7.5",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
